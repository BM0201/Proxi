{
  "name": "proxi",
  "version": "0.1.0",
  "private": true,
  "description": "Proxi - Marketplace de servicios por tarea que conecta clientes con proveedores independientes verificados",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "turbo run db:generate",
    "db:migrate": "pnpm --filter @proxi/database db:migrate",
    "db:seed": "pnpm --filter @proxi/database db:seed",
    "db:studio": "pnpm --filter @proxi/database db:studio",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@proxi/eslint-config": "workspace:*",
    "@proxi/tsconfig": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
