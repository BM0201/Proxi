// Schema de Prisma para la plataforma Proxi
// Marketplace de servicios por tarea que conecta clientes con proveedores
// independientes verificados (pago protegido, saldo aprobado, liquidación).
//
// Terminología:
//  - Proveedor independiente (NO empleado)
//  - Saldo aprobado / saldo disponible (availableBalance)
//  - Liquidación (Payout)
//  - Pago protegido (escrow representado mediante el ledger)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// ENUMS
// ===========================================================================

enum UserRole {
  CLIENT
  PROVIDER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING_EMAIL_VERIFICATION
  SUSPENDED
  BANNED
}

enum ProviderLevel {
  LEVEL_0
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4_PRO
  LEVEL_5_PREMIUM
}

enum ProviderVerificationStatus {
  NOT_STARTED
  PENDING_REVIEW
  APPROVED
  REJECTED
  NEEDS_CORRECTION
}

enum CertificationStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum TaskStatus {
  DRAFT
  PUBLISHED
  RECEIVING_OFFERS
  OFFER_ACCEPTED
  PROTECTED_PAYMENT_CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum OfferStatus {
  SENT
  VIEWED
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  EXPIRED
  WITHDRAWN
}

enum BookingStatus {
  CONFIRMED
  PENDING_PAYMENT
  PAID
  IN_PROGRESS
  COMPLETED_BY_PROVIDER
  CONFIRMED_BY_CLIENT
  COMPLETED
  CANCELLED
  DISPUTED
}

enum ProtectedPaymentStatus {
  NOT_STARTED
  PENDING
  PROTECTED
  APPROVED_FOR_PAYOUT
  DISPUTED
  REFUNDED
}

enum PricingType {
  FIXED
  HOURLY
  DAILY
  TECHNICAL_VISIT
  OPEN_TO_OFFERS
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum LedgerEntryType {
  CREDIT
  DEBIT
  HOLD
  RELEASE
}

enum ModerationEntityType {
  TASK
  OFFER
  REVIEW
  CHAT_MESSAGE
  PROVIDER_PROFILE
}

enum ModerationStatus {
  OPEN
  REVIEWED
  ACTIONED
  DISMISSED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum MediaPurpose {
  AVATAR
  PROVIDER_PORTFOLIO
  VERIFICATION_DOCUMENT
  VERIFICATION_SELFIE
  TASK_PHOTO
  TASK_VIDEO
  BOOKING_EVIDENCE
  DISPUTE_EVIDENCE
}

enum MediaStatus {
  UPLOADED
  PENDING_REVIEW
  APPROVED
  REJECTED
  DELETED
}

enum LocationVisibility {
  PRIVATE
  APPROXIMATE
  BOOKING_ONLY
}

enum NotificationType {
  TASK_UPDATE
  OFFER_RECEIVED
  BOOKING_UPDATE
  PAYMENT_UPDATE
  PAYOUT_UPDATE
  DISPUTE_UPDATE
  CHAT_MESSAGE
  SYSTEM
}

// ===========================================================================
// IDENTIDAD Y PERFILES
// ===========================================================================

/// Usuario base de la plataforma. Puede ser cliente, proveedor o administrador.
model User {
  id              String     @id @default(cuid())
  email           String     @unique
  passwordHash    String
  role            UserRole   @default(CLIENT)
  status          UserStatus @default(PENDING_EMAIL_VERIFICATION)
  displayName     String?
  emailVerifiedAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  clientProfile   ClientProfile?
  providerProfile ProviderProfile?
  ledgerAccount   LedgerAccount?

  tasks            Task[]           @relation("ClientTasks")
  offers           Offer[]          @relation("ProviderOffers")
  clientBookings   Booking[]        @relation("ClientBookings")
  providerBookings Booking[]        @relation("ProviderBookings")
  payouts          Payout[]
  reviewsAuthored  Review[]         @relation("ReviewAuthor")
  reviewsReceived  Review[]         @relation("ReviewSubject")
  disputes         Dispute[]        @relation("DisputeInitiator")
  chatMessages     ChatMessage[]
  moderationFlags  ModerationFlag[]
  mediaFiles       MediaFile[]      @relation("MediaOwner")
  notifications    Notification[]
  auditLogs        AuditLog[]
  locations        Location[]
  reviewedProviderVerifications ProviderVerification[] @relation("ProviderVerificationReviewer")
  reviewedProviderCertifications ProviderCertification[] @relation("ProviderCertificationReviewer")

  @@index([role])
  @@index([status])
}

/// Perfil de cliente: datos adicionales del usuario que contrata servicios.
model ClientProfile {
  id            String     @id @default(cuid())
  userId        String     @unique
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName   String
  avatarMediaId String?
  avatarMedia   MediaFile? @relation("ClientAvatar", fields: [avatarMediaId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

/// Perfil de proveedor independiente: estado de verificación, biografía y tarifa.
model ProviderProfile {
  id                 String                     @id @default(cuid())
  userId             String                     @unique
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName        String
  bio                String?
  level              ProviderLevel              @default(LEVEL_0)
  ratingAverage      Float                      @default(0)
  ratingCount        Int                        @default(0)
  completedJobs      Int                        @default(0)
  verificationStatus ProviderVerificationStatus @default(NOT_STARTED)
  avatarMediaId      String?
  avatarMedia        MediaFile?                 @relation("ProviderAvatar", fields: [avatarMediaId], references: [id])
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  servicePackages ServicePackage[]
  verifications   ProviderVerification[]
  certifications  ProviderCertification[]

  @@index([verificationStatus])
  @@index([level])
}

// ===========================================================================
// CATÁLOGO Y MARKETPLACE
// ===========================================================================

/// Categoría de servicio (ej. Fontanería, Limpieza, Clases particulares).
model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  servicePackages ServicePackage[]
  tasks           Task[]
}

/// Paquete de servicio ofrecido por un proveedor dentro de una categoría.
model ServicePackage {
  id          String          @id @default(cuid())
  providerId  String
  provider    ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  title       String
  description String?
  price       Decimal         @db.Decimal(10, 2)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([providerId])
  @@index([categoryId])
}

/// Tarea publicada por un cliente para recibir ofertas de proveedores.
model Task {
  id          String     @id @default(cuid())
  clientId    String
  client      User       @relation("ClientTasks", fields: [clientId], references: [id])
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])
  categoryName String    @default("General")
  locationId  String?
  location    Location?  @relation(fields: [locationId], references: [id])
  title       String
  description String
  status      TaskStatus @default(DRAFT)
  budget      Decimal?   @db.Decimal(10, 2)
  budgetMin   Decimal?   @db.Decimal(10, 2)
  budgetMax   Decimal?   @db.Decimal(10, 2)
  pricingType PricingType @default(OPEN_TO_OFFERS)
  city        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  offers     Offer[]
  booking    Booking?
  chatThread ChatThread?

  @@index([clientId])
  @@index([categoryId])
  @@index([locationId])
  @@index([status])
}

/// Oferta enviada por un proveedor a una tarea publicada.
model Offer {
  id         String      @id @default(cuid())
  taskId     String
  task       Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  providerId String
  provider   User        @relation("ProviderOffers", fields: [providerId], references: [id])
  price      Decimal     @db.Decimal(10, 2)
  amount     Decimal     @db.Decimal(10, 2)
  estimatedDuration String?
  includesMaterials Boolean @default(false)
  requiresTechnicalVisit Boolean @default(false)
  contactWarning Boolean @default(false)
  status     OfferStatus @default(SENT)
  message    String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  booking Booking?

  @@unique([taskId, providerId])
  @@index([taskId])
  @@index([providerId])
}

// ===========================================================================
// RESERVAS, PAGOS Y LIQUIDACIONES
// ===========================================================================

/// Reserva (pago protegido) generada al aceptar una oferta.
model Booking {
  id          String        @id @default(cuid())
  taskId      String        @unique
  task        Task          @relation(fields: [taskId], references: [id])
  offerId     String        @unique
  offer       Offer         @relation(fields: [offerId], references: [id])
  clientId    String
  client      User          @relation("ClientBookings", fields: [clientId], references: [id])
  providerId  String
  provider    User          @relation("ProviderBookings", fields: [providerId], references: [id])
  status      BookingStatus @default(CONFIRMED)
  protectedPaymentStatus ProtectedPaymentStatus @default(NOT_STARTED)
  agreedPrice Decimal       @db.Decimal(10, 2)
  totalAmount Decimal       @db.Decimal(10, 2)
  platformFee Decimal       @db.Decimal(10, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  extras        BookingExtra[]
  payment       Payment?
  review        Review[]
  dispute       Dispute?
  ledgerEntries LedgerEntry[]

  @@index([clientId])
  @@index([providerId])
  @@index([status])
}

/// Extra o ajuste adicional agregado a una reserva.
model BookingExtra {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  @@index([bookingId])
}

/// Pago realizado por el cliente sobre una reserva (pago protegido).
model Payment {
  id            String        @id @default(cuid())
  bookingId     String        @unique
  booking       Booking       @relation(fields: [bookingId], references: [id])
  amount        Decimal       @db.Decimal(10, 2)
  status        PaymentStatus @default(PENDING)
  paymentMethod String
  transactionId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
}

/// Cuenta del libro mayor (ledger) asociada a un usuario.
/// Representa el saldo: total, reservado (pago protegido) y aprobado/disponible.
model LedgerAccount {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance          Decimal  @default(0) @db.Decimal(12, 2)
  reservedBalance  Decimal  @default(0) @db.Decimal(12, 2)
  availableBalance Decimal  @default(0) @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  entries LedgerEntry[]
}

/// Movimiento del libro mayor: crédito, débito, reserva (hold) o liberación.
model LedgerEntry {
  id          String          @id @default(cuid())
  accountId   String
  account     LedgerAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type        LedgerEntryType
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  bookingId   String?
  booking     Booking?        @relation(fields: [bookingId], references: [id])
  createdAt   DateTime        @default(now())

  @@index([accountId])
  @@index([bookingId])
}

/// Liquidación (payout) de saldo aprobado hacia el proveedor independiente.
model Payout {
  id          String       @id @default(cuid())
  providerId  String
  provider    User         @relation(fields: [providerId], references: [id])
  amount      Decimal      @db.Decimal(12, 2)
  status      PayoutStatus @default(PENDING)
  bankDetails String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([providerId])
  @@index([status])
}

// ===========================================================================
// REPUTACIÓN Y DISPUTAS
// ===========================================================================

/// Reseña de una reserva: el autor evalúa al evaluado (cliente o proveedor).
model Review {
  id         String   @id @default(cuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User     @relation("ReviewAuthor", fields: [reviewerId], references: [id])
  revieweeId String
  reviewee   User     @relation("ReviewSubject", fields: [revieweeId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([bookingId, reviewerId])
  @@index([revieweeId])
}

/// Disputa abierta sobre una reserva.
model Dispute {
  id          String        @id @default(cuid())
  bookingId   String        @unique
  booking     Booking       @relation(fields: [bookingId], references: [id])
  initiatorId String
  initiator   User          @relation("DisputeInitiator", fields: [initiatorId], references: [id])
  status      DisputeStatus @default(OPEN)
  reason      String
  resolution  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
}

// ===========================================================================
// MENSAJERÍA
// ===========================================================================

/// Hilo de conversación asociado a una tarea.
model ChatThread {
  id             String   @id @default(cuid())
  taskId         String   @unique
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  participantIds String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages ChatMessage[]
}

/// Mensaje individual dentro de un hilo de conversación.
model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User       @relation(fields: [senderId], references: [id])
  content   String
  readAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([threadId])
  @@index([senderId])
}

// ===========================================================================
// MODERACIÓN, MEDIA, NOTIFICACIONES Y AUDITORÍA
// ===========================================================================

/// Marca de moderación: reporte sobre una entidad de la plataforma.
model ModerationFlag {
  id         String               @id @default(cuid())
  entityType ModerationEntityType
  entityId   String
  reporterId String
  reporter   User                 @relation(fields: [reporterId], references: [id])
  reason     String
  status     ModerationStatus     @default(OPEN)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([entityType, entityId])
  @@index([status])
}

/// Archivo multimedia subido por un usuario.
model MediaFile {
  id          String       @id @default(cuid())
  ownerUserId String
  owner       User         @relation("MediaOwner", fields: [ownerUserId], references: [id])
  purpose     MediaPurpose
  fileName    String
  originalName String
  mimeType    String
  sizeBytes   Int
  storageKey  String
  publicUrl   String?
  privateUrl  String?
  status      MediaStatus  @default(UPLOADED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  clientAvatarProfiles   ClientProfile[]   @relation("ClientAvatar")
  providerAvatarProfiles ProviderProfile[] @relation("ProviderAvatar")
  providerVerificationFront ProviderVerification[] @relation("ProviderVerificationFront")
  providerVerificationBack  ProviderVerification[] @relation("ProviderVerificationBack")
  providerVerificationSelfie ProviderVerification[] @relation("ProviderVerificationSelfie")
  providerCertifications ProviderCertification[]

  @@index([ownerUserId])
  @@index([purpose])
  @@index([status])
}

/// Verificación manual de identidad de proveedor independiente.
model ProviderVerification {
  id                           String                     @id @default(cuid())
  providerId                   String
  provider                     ProviderProfile            @relation(fields: [providerId], references: [id], onDelete: Cascade)
  status                       ProviderVerificationStatus @default(PENDING_REVIEW)
  identityDocumentFrontMediaId String
  identityDocumentFrontMedia   MediaFile                  @relation("ProviderVerificationFront", fields: [identityDocumentFrontMediaId], references: [id])
  identityDocumentBackMediaId  String?
  identityDocumentBackMedia    MediaFile?                 @relation("ProviderVerificationBack", fields: [identityDocumentBackMediaId], references: [id])
  selfieMediaId                String?
  selfieMedia                  MediaFile?                 @relation("ProviderVerificationSelfie", fields: [selfieMediaId], references: [id])
  notes                        String?
  reviewedByAdminId            String?
  reviewedByAdmin              User?                      @relation("ProviderVerificationReviewer", fields: [reviewedByAdminId], references: [id])
  reviewedAt                   DateTime?
  rejectionReason              String?
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt

  @@index([providerId])
  @@index([status])
  @@index([reviewedByAdminId])
}

/// Certificación o evidencia profesional aportada por un proveedor.
model ProviderCertification {
  id                String              @id @default(cuid())
  providerId        String
  provider          ProviderProfile     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  title             String
  issuer            String?
  mediaId           String
  media             MediaFile           @relation(fields: [mediaId], references: [id])
  status            CertificationStatus @default(PENDING_REVIEW)
  reviewedByAdminId String?
  reviewedByAdmin   User?               @relation("ProviderCertificationReviewer", fields: [reviewedByAdminId], references: [id])
  reviewedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([providerId])
  @@index([status])
}

/// Ubicación de cliente o tarea, con soporte para privacidad de dirección exacta.
model Location {
  id             String             @id @default(cuid())
  ownerUserId    String?
  owner          User?              @relation(fields: [ownerUserId], references: [id])
  label          String?
  country        String             @default("Nicaragua")
  department     String
  city           String
  zone           String
  addressLine1   String
  addressLine2   String?
  latitude       Float?
  longitude      Float?
  accuracyMeters Int?
  isExact        Boolean            @default(false)
  visibility     LocationVisibility @default(APPROXIMATE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  tasks Task[]

  @@index([ownerUserId])
  @@index([visibility])
  @@index([city, zone])
}

/// Notificación dirigida a un usuario.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  content   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([read])
}

/// Registro de auditoría de acciones relevantes en la plataforma.
/// Presente desde el inicio para trazabilidad y cumplimiento.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  changes    Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
}
